        # Validation croisee : metriques calculees vs scores IA
        ("avg_words_per_msg", "qualite_global",    "Moy mots/msg",      "Qualite globale IA"),
        ("avg_ttr",           "qualite_richesse",  "Richesse lexicale",  "Score richesse IA"),
