        ("avg_words_per_msg", "profil_engagement", "Moy mots/msg",       "Engagement IA"),
        # Entre VD textuelles
        ("qualite_global",    "action_global",     "Qualite globale",    "Actionabilite globale"),
        ("profil_engagement", "qualite_global",    "Engagement",         "Qualite globale"),
        ("profil_expertise",  "action_global",     "Expertise percue",   "Actionabilite"),
        ("n_turns",           "qualite_global",    "Nb tours",           "Qualite globale"),
        ("rupture_tour",      "qualite_global",    "Tour de rupture",    "Qualite globale"),
        # Conformite brief vs marqueurs
        ("bot_conformite_score","bot_tutoiement",  "Conformite brief",   "Tutoiement"),
        ("bot_conformite_score","bot_emojis",      "Conformite brief",   "Emojis utilises"),
        ("bot_conformite_score","bot_nb_mots_amicaux","Conformite brief","Nb mots amicaux"),
        ("bot_conformite_score","bot_nb_encouragements","Conformite brief","Nb encouragements"),
        ("bot_score_amical",  "bot_conformite_score","Score amical",     "Conformite brief"),
        # Ton chatbot vs qualite participant
        ("bot_score_amical",  "qualite_global",   "Score amical chatbot","Qualite participant"),
        ("bot_score_amical",  "profil_engagement","Score amical chatbot","Engagement participant"),
        ("bot_conformite_score","qualite_global", "Conformite brief",    "Qualite participant"),
