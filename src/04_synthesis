def analyse_conformite_brief(df):
    """
    Analyse de conformite au brief :
    - Par participant : score conformite et ecart detecte
    - Par ton : moyennes, distribution, % conformes
    - Correlations marqueurs -> score conformite
    """
    summary = {}

    for version in ["FL_21", "FL_22"]:
        grp = df[df["version"] == version]
        summary[version] = {
            "n":                     len(grp),
            "conformite_score_mean": round(grp["bot_conformite_score"].mean(), 3) if "bot_conformite_score" in grp else None,
            "conformite_score_sd":   round(grp["bot_conformite_score"].std(), 3)  if "bot_conformite_score" in grp else None,
            "pct_conforme":          round(grp["bot_conforme"].mean()*100, 1)     if "bot_conforme" in grp else None,
            "pct_emojis":            round(grp["bot_emojis"].mean()*100, 1)       if "bot_emojis" in grp else None,
            "pct_tutoiement":        round(grp["bot_tutoiement"].mean()*100, 1)   if "bot_tutoiement" in grp else None,
            "pct_vouvoiement":       round(grp["bot_vouvoiement"].mean()*100, 1)  if "bot_vouvoiement" in grp else None,
            "moy_encouragements":    round(grp["bot_nb_encouragements"].mean(), 2) if "bot_nb_encouragements" in grp else None,
            "moy_formules_sobres":   round(grp["bot_nb_formules_sobres"].mean(), 2) if "bot_nb_formules_sobres" in grp else None,
        }

    # Test t sur score conformite
    ttest_conf = ttest_by_version(df, "bot_conformite_score", "Score conformite au brief")

    return {"par_version": summary, "ttest_conformite": ttest_conf}


def analyse_abandons(df):
    """
    Profil comparatif des abandonneurs vs completeurs.
    Et comparaison abandons FL_21 vs FL_22.
    """
    # Definiton : abandon = fin_jusqu_au_bout = 0
    df["abandon"] = (df["fin_jusqu_au_bout"] == 0).astype(int)
    abandonneurs  = df[df["abandon"] == 1]
    completeurs   = df[df["abandon"] == 0]

    vars_profil = [
        ("qualite_global",    "Qualite globale"),
        ("action_global",     "Actionabilite"),
        ("profil_engagement", "Engagement"),
        ("profil_expertise",  "Expertise percue"),
        ("n_turns",           "Nb tours"),
        ("avg_words_per_msg", "Moy mots/message"),
    ]

    comparaison = []
    for col, lbl in vars_profil:
        if col not in df.columns:
            continue
        g_ab  = abandonneurs[col].dropna().values
        g_co  = completeurs[col].dropna().values
        if len(g_ab) < 2 or len(g_co) < 2:
            continue
        t_s, p_v = stats.ttest_ind(g_ab, g_co)
        d        = cohens_d(g_ab, g_co)
        comparaison.append({
            "variable":       col,
            "label":          lbl,
            "mean_abandonneurs": round(float(np.mean(g_ab)), 3),
            "sd_abandonneurs":   round(float(np.std(g_ab, ddof=1)), 3),
            "mean_completeurs":  round(float(np.mean(g_co)), 3),
            "sd_completeurs":    round(float(np.std(g_co, ddof=1)), 3),
            "t":              round(float(t_s), 4),
            "p":              round(float(p_v), 4),
            "sig":            sig_label(p_v),
            "cohens_d":       round(float(d), 3) if not np.isnan(d) else None,
            "effet":          interpret_d(d),
        })

    # Distribution types de fin par version
    fin_dist = {}
    for version in ["FL_21", "FL_22"]:
        grp  = df[df["version"] == version]
        dist = grp["fin_type"].value_counts(normalize=True) * 100
        fin_dist[version] = {k: round(v, 1) for k, v in dist.items()}

    # Distribution globale
    dist_global = df["fin_type"].value_counts(normalize=True) * 100
    fin_dist["global"] = {k: round(v, 1) for k, v in dist_global.items()}

    return {
        "n_abandonneurs":      int(df["abandon"].sum()),
        "n_completeurs":       int((df["abandon"] == 0).sum()),
        "pct_abandon_global":  round(df["abandon"].mean() * 100, 1),
        "pct_abandon_fl21":    round(df[df["version"]=="FL_21"]["abandon"].mean()*100, 1),
        "pct_abandon_fl22":    round(df[df["version"]=="FL_22"]["abandon"].mean()*100, 1),
        "comparaison_profil":  comparaison,
        "distribution_fin":    fin_dist,
    }


def analyse_progression(df_prog):
    """
    Analyse de la progression des scores qualite par tour.
    Moyennes par tour et par version pour tracer une courbe.
    """
    if df_prog.empty:
        return {}

    # Moyenne score qualite par tour et version
    pivot = df_prog.groupby(["version","tour"])["score_qualite"].agg(
        mean="mean", sd="std", n="count"
    ).reset_index()

    result = {"FL_21": {}, "FL_22": {}}
    for _, row in pivot.iterrows():
        ver = row["version"]
        t   = int(row["tour"])
        result[ver][t] = {
            "mean": round(row["mean"], 3),
            "sd":   round(row["sd"], 3) if not pd.isna(row["sd"]) else None,
            "n":    int(row["n"]),
        }

    # Tour moyen de rupture par version
    rupture = {}
    if "rupture_tour" in df_prog.columns:
        pass  # deja dans df_merged

    return result


